<%- include('partials/head') %>
<%- include('partials/header') %>

<section class="section shop-page-section">
  <div class="container">
    <div class="shop-page-header">
      <div class="section-title">
        <h1 class="title">Shop</h1>
      </div>

      <p class="shop-page-subtitle">
        Temukan produk pilihan terbaik dengan tampilan yang rapi, cepat, dan nyaman untuk belanja di mobile maupun desktop.
      </p>
    </div>

    <div class="row">
      <% if (products && products.length) { %>
        <% products.forEach(function(product){ %>
          <div class="col-md-3 col-sm-6 col-xs-6">
            <%- include('partials/product-card', { product: product }) %>
          </div>
        <% }) %>
      <% } else { %>
        <div class="col-md-12">
          <div class="empty-box text-center shop-empty-state">
            <h3>Produk belum tersedia</h3>
            <p>Tidak ada produk ditemukan saat ini. Coba lagi nanti atau gunakan pencarian untuk produk lain.</p>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
