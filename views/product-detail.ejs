<%- include('partials/head') %>
<%- include('partials/header') %>
<div class="section"><div class="container"><div class="row">
  <div class="col-md-5 col-md-push-2"><div id="product-main-img" class="product-preview"><img src="<%= product.thumbnail %>" alt="<%= product.name %>"></div></div>
  <div class="col-md-2 col-md-pull-5"><div id="product-imgs" class="thumb-list"><% product.images.forEach(function(img){ %><div class="product-preview mb-15"><img src="<%= img %>" alt="<%= product.name %>"></div><% }) %></div></div>
  <div class="col-md-5"><div class="product-details">
    <h2 class="product-name"><%= product.name %></h2>
    <div><h3 class="product-price">THB <%= product.price_thb.toLocaleString('en-US') %> <% if (product.price_idr) { %><small>| IDR <%= product.price_idr.toLocaleString('en-US') %></small><% } %>
      <% if (product.compare_price_thb || product.compare_price_idr) { %><del class="product-old-price"><% if (product.compare_price_thb) { %>THB <%= product.compare_price_thb.toLocaleString('en-US') %><% } %> <% if (product.compare_price_idr) { %>| IDR <%= product.compare_price_idr.toLocaleString('en-US') %><% } %></del><% } %>
    </h3><span class="product-available"><%= product.status === 'sold_out' ? 'Sold Out' : 'In Stock' %></span></div>
    <p><%= product.short_description %></p>
    <div class="add-to-cart">
      <% if (product.status === 'sold_out') { %><button class="add-to-cart-btn" type="button" disabled><i class="fa fa-ban"></i> sold out</button>
      <% } else { %>
      <form method="post" action="/cart/add" style="display:flex;gap:10px;align-items:center;">
        <input type="hidden" name="product_id" value="<%= product.id %>">
        <input type="number" name="qty" value="1" min="1" class="input" style="width:90px;">
        <button class="add-to-cart-btn"><i class="fa fa-shopping-cart"></i> add to cart</button>
      </form>
      <% } %>
    </div>
    <ul class="product-links"><li>Category:</li><li><a href="/shop?category=<%= encodeURIComponent(product.category) %>"><%= product.category %></a></li></ul>
    <ul class="product-links"><li>Brand:</li><li><a href="#"><%= product.brand %></a></li></ul>
    <div class="mt-15"><%- product.description %></div>
    <div class="mt-15"><%- product.details %></div>
  </div></div>
</div></div></div>
<div class="section"><div class="container"><div class="row"><div class="col-md-12"><div class="section-title"><h3 class="title">Recommended Products</h3></div></div>
  <% recommended.forEach(function(product){ %><div class="col-md-3 col-sm-6 col-xs-6"><%- include('partials/product-card', { product }) %></div><% }) %>
</div></div></div>
<%- include('partials/footer') %>
