<%- include('partials/head') %>
<%- include('partials/header') %>

<section class="section product-detail-section">
  <div class="container">
    <div class="row product-detail-row">
      <div class="col-md-7 col-sm-12 col-xs-12 product-gallery-column">
        <div class="product-gallery-wrap">
          <div class="product-main-preview" id="product-main-preview">
            <button
              type="button"
              class="product-zoom-btn"
              id="open-image-popup"
              aria-label="Lihat gambar lebih besar"
            >
              <i class="fa fa-search-plus"></i>
            </button>

            <img
              id="main-product-image"
              src="<%= product.thumbnail %>"
              alt="<%= product.name %>"
              loading="eager"
            >
          </div>

          <div class="thumb-list" id="product-thumb-list">
            <button
              type="button"
              class="product-thumb-item active"
              data-image="<%= product.thumbnail %>"
              aria-label="Gambar utama <%= product.name %>"
            >
              <img src="<%= product.thumbnail %>" alt="<%= product.name %>" loading="lazy">
            </button>

            <% if (product.images && product.images.length) { %>
              <% product.images.forEach(function(img){ %>
                <% if (img && img !== product.thumbnail) { %>
                  <button
                    type="button"
                    class="product-thumb-item"
                    data-image="<%= img %>"
                    aria-label="Thumbnail <%= product.name %>"
                  >
                    <img src="<%= img %>" alt="<%= product.name %>" loading="lazy">
                  </button>
                <% } %>
              <% }) %>
            <% } %>
          </div>
        </div>
      </div>

      <div class="col-md-5 col-sm-12 col-xs-12 product-info-column">
        <div class="product-details">
          <h1 class="product-name"><%= product.name %></h1>

          <div class="product-price-wrap">
            <h2 class="product-price">
              THB <%= product.price_thb.toLocaleString('en-US') %>
              <% if (product.price_idr) { %>
                <small>| IDR <%= product.price_idr.toLocaleString('en-US') %></small>
              <% } %>

              <% if (product.compare_price_thb || product.compare_price_idr) { %>
                <del class="product-old-price">
                  <% if (product.compare_price_thb) { %>
                    THB <%= product.compare_price_thb.toLocaleString('en-US') %>
                  <% } %>
                  <% if (product.compare_price_idr) { %>
                    | IDR <%= product.compare_price_idr.toLocaleString('en-US') %>
                  <% } %>
                </del>
              <% } %>
            </h2>

            <span class="product-available">
              <%= product.status === 'sold_out' ? 'Sold Out' : 'In Stock' %>
            </span>
          </div>

          <% if (product.short_description) { %>
            <p class="product-short-description"><%= product.short_description %></p>
          <% } %>

          <div class="add-to-cart">
            <% if (product.status === 'sold_out') { %>
              <button class="add-to-cart-btn" type="button" disabled>
                <i class="fa fa-ban"></i> Sold Out
              </button>
            <% } else { %>
              <form method="post" action="/cart/add" class="add-to-cart-form">
                <input type="hidden" name="product_id" value="<%= product.id %>">
                <label class="sr-only" for="qty-input">Jumlah</label>
                <input id="qty-input" type="number" name="qty" value="1" min="1" class="input qty-input">

                <button class="add-to-cart-btn" type="submit">
                  <i class="fa fa-shopping-cart"></i> Add to Cart
                </button>
              </form>
            <% } %>
          </div>

          <ul class="product-links">
            <li>Category:</li>
            <li>
              <a href="/shop?category=<%= encodeURIComponent(product.category) %>">
                <%= product.category %>
              </a>
            </li>
          </ul>

          <% if (product.brand) { %>
            <ul class="product-links">
              <li>Brand:</li>
              <li><span><%= product.brand %></span></li>
            </ul>
          <% } %>

          <% if (product.description) { %>
            <div class="mt-15 product-description-content">
              <%- product.description %>
            </div>
          <% } %>

          <% if (product.details) { %>
            <div class="mt-15 product-details-content">
              <%- product.details %>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section recommended-products-section">
  <div class="container">
    <div class="row">
      <div class="col-md-12">
        <div class="section-title">
          <h2 class="title">Recommended Products</h2>
        </div>
      </div>

      <% if (recommended && recommended.length) { %>
        <% recommended.forEach(function(product){ %>
          <div class="col-md-3 col-sm-6 col-xs-6">
            <%- include('partials/product-card', { product: product }) %>
          </div>
        <% }) %>
      <% } else { %>
        <div class="col-md-12">
          <div class="empty-box text-center">
            Belum ada produk rekomendasi.
          </div>
        </div>
      <% } %>
    </div>
  </div>
</section>

<div class="product-image-modal" id="product-image-modal" aria-hidden="true">
  <div class="product-image-modal-backdrop" id="product-image-modal-backdrop"></div>
  <div class="product-image-modal-dialog" role="dialog" aria-modal="true" aria-label="Preview gambar produk">
    <button type="button" class="product-image-modal-close" id="close-image-popup" aria-label="Tutup preview">
      <i class="fa fa-times"></i>
    </button>
    <img id="popup-product-image" src="<%= product.thumbnail %>" alt="<%= product.name %>">
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var mainImage = document.getElementById('main-product-image');
    var popupImage = document.getElementById('popup-product-image');
    var thumbs = document.querySelectorAll('.product-thumb-item');
    var modal = document.getElementById('product-image-modal');
    var openPopupBtn = document.getElementById('open-image-popup');
    var closePopupBtn = document.getElementById('close-image-popup');
    var modalBackdrop = document.getElementById('product-image-modal-backdrop');

    function setActiveImage(newImage, clickedThumb) {
      if (!newImage || !mainImage) return;
      mainImage.setAttribute('src', newImage);
      if (popupImage) popupImage.setAttribute('src', newImage);

      thumbs.forEach(function (item) {
        item.classList.remove('active');
      });

      if (clickedThumb) {
        clickedThumb.classList.add('active');
      }
    }

    thumbs.forEach(function (thumb) {
      thumb.addEventListener('click', function () {
        var newImage = this.getAttribute('data-image');
        setActiveImage(newImage, this);
      });
    });

    function openModal() {
      if (!modal || !popupImage || !mainImage) return;
      popupImage.setAttribute('src', mainImage.getAttribute('src'));
      modal.classList.add('is-open');
      document.body.classList.add('modal-open');
    }

    function closeModal() {
      if (!modal) return;
      modal.classList.remove('is-open');
      document.body.classList.remove('modal-open');
    }

    if (openPopupBtn) {
      openPopupBtn.addEventListener('click', openModal);
    }

    if (mainImage) {
      mainImage.addEventListener('click', openModal);
      mainImage.style.cursor = 'zoom-in';
    }

    if (closePopupBtn) {
      closePopupBtn.addEventListener('click', closeModal);
    }

    if (modalBackdrop) {
      modalBackdrop.addEventListener('click', closeModal);
    }

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') {
        closeModal();
      }
    });
  });
</script>

<%- include('partials/footer') %>
