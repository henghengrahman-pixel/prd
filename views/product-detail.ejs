<%- include('partials/head') %>
<%- include('partials/header') %>

<section class="section product-detail-section">
  <div class="container">
    <div class="product-breadcrumb">
      <a href="/">Home</a>
      <span>/</span>
      <a href="/shop">Shop</a>
      <% if (product.category) { %>
        <span>/</span>
        <a href="/shop?category=<%= encodeURIComponent(product.category) %>">
          <%= product.category %>
        </a>
      <% } %>
      <span>/</span>
      <span><%= product.name %></span>
    </div>

    <div class="row product-detail-row">
      <div class="col-md-7 col-sm-12 col-xs-12 product-gallery-column">
        <div class="product-gallery-wrap">
          <div class="product-main-preview" id="product-main-preview">
            <button
              type="button"
              class="product-zoom-btn"
              id="open-image-popup"
              aria-label="Lihat gambar lebih besar"
            >
              <i class="fa fa-search-plus"></i>
            </button>

            <img
              id="main-product-image"
              src="<%= product.thumbnail %>"
              alt="<%= product.name %>"
              loading="eager"
            >
          </div>

          <div class="mobile-swipe-hint">Geser kiri / kanan untuk melihat foto lain</div>

          <div class="thumb-list" id="product-thumb-list">
            <button
              type="button"
              class="product-thumb-item active"
              data-image="<%= product.thumbnail %>"
            >
              <img src="<%= product.thumbnail %>" alt="<%= product.name %>" loading="lazy">
            </button>

            <% if (product.images && product.images.length) { %>
              <% product.images.forEach(function(img){ %>
                <% if (img && img !== product.thumbnail) { %>
                  <button
                    type="button"
                    class="product-thumb-item"
                    data-image="<%= img %>"
                  >
                    <img src="<%= img %>" alt="<%= product.name %>" loading="lazy">
                  </button>
                <% } %>
              <% }) %>
            <% } %>
          </div>
        </div>
      </div>

      <div class="col-md-5 col-sm-12 col-xs-12 product-info-column">
        <div class="product-details">
          <h1 class="product-name"><%= product.name %></h1>

          <div class="product-price-wrap">
            <h2 class="product-price">
              THB <%= Number(product.price_thb || 0).toLocaleString('en-US') %>

              <% if (product.price_idr) { %>
                <small>| IDR <%= Number(product.price_idr || 0).toLocaleString('en-US') %></small>
              <% } %>

              <% if (product.compare_price_thb || product.compare_price_idr) { %>
                <del class="product-old-price">
                  <% if (product.compare_price_thb) { %>
                    THB <%= Number(product.compare_price_thb || 0).toLocaleString('en-US') %>
                  <% } %>
                  <% if (product.compare_price_idr) { %>
                    | IDR <%= Number(product.compare_price_idr || 0).toLocaleString('en-US') %>
                  <% } %>
                </del>
              <% } %>
            </h2>

            <span class="product-available">
              <%= product.status === 'sold_out' ? 'Sold Out' : 'In Stock' %>
            </span>
          </div>

          <% if (product.short_description) { %>
            <p class="product-short-description"><%= product.short_description %></p>
          <% } %>

          <div class="product-buy-actions">
            <% if (product.status === 'sold_out') { %>
              <button class="buy-now-btn" type="button" disabled>Sold Out</button>
              <button class="add-to-cart-btn" type="button" disabled>Sold Out</button>
            <% } else { %>
              <form method="post" action="/buy-now" class="buy-now-form">
                <input type="hidden" name="product_id" value="<%= product.id %>">
                <input type="hidden" name="qty" value="1">
                <button type="submit" class="buy-now-btn">
                  Beli Sekarang
                </button>
              </form>

              <form method="post" action="/cart/add" class="add-to-cart-form">
                <input type="hidden" name="product_id" value="<%= product.id %>">
                <input type="number" name="qty" value="1" min="1" class="input qty-input">
                <button class="add-to-cart-btn" type="submit">
                  <i class="fa fa-shopping-cart"></i> Tambah ke Keranjang
                </button>
              </form>
            <% } %>
          </div>

          <% if (product.category) { %>
            <ul class="product-links">
              <li>Category:</li>
              <li>
                <a href="/shop?category=<%= encodeURIComponent(product.category) %>">
                  <%= product.category %>
                </a>
              </li>
            </ul>
          <% } %>

          <% if (product.brand) { %>
            <ul class="product-links">
              <li>Brand:</li>
              <li><span><%= product.brand %></span></li>
            </ul>
          <% } %>

          <% if (product.description) { %>
            <div class="product-description-content mt-15">
              <%- product.description %>
            </div>
          <% } %>

          <% if (product.details) { %>
            <div class="product-details-content mt-15">
              <%- product.details %>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section recommended-products-section">
  <div class="container">
    <div class="section-title">
      <h2 class="title">Produk Rekomendasi</h2>
    </div>

    <div class="row">
      <% if (recommended && recommended.length) { %>
        <% recommended.forEach(function(product){ %>
          <div class="col-md-3 col-sm-6 col-xs-6">
            <%- include('partials/product-card', { product: product }) %>
          </div>
        <% }) %>
      <% } else { %>
        <div class="col-md-12">
          <div class="empty-box text-center">
            Belum ada produk rekomendasi.
          </div>
        </div>
      <% } %>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
