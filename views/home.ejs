<%- include('partials/head') %>
<%- include('partials/header') %>

<section class="section home-hero-section">
  <div class="container">
    <div class="row">
      <% categories.slice(0, 3).forEach(function(cat, idx){ %>
        <div class="col-md-4 col-sm-6 col-xs-12">
          <div class="shop home-category-card">
            <div class="shop-img">
              <img
                src="<%= products[idx] ? products[idx].thumbnail : settings.logo %>"
                alt="<%= cat.name %>"
                loading="lazy"
              >
            </div>
            <div class="shop-body">
              <h3><%= cat.name %><br>Collection</h3>
              <a href="/shop?category=<%= encodeURIComponent(cat.name) %>" class="cta-btn">
                Shop Now <i class="fa fa-arrow-circle-right"></i>
              </a>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<section class="section home-products-section">
  <div class="container">
    <div class="row">
      <div class="col-md-12">
        <div class="section-title">
          <h2 class="title">Featured Products</h2>
        </div>
      </div>

      <% if (featured && featured.length) { %>
        <% featured.forEach(function(product){ %>
          <div class="col-md-3 col-sm-6 col-xs-6">
            <%- include('partials/product-card', { product: product }) %>
          </div>
        <% }) %>
      <% } else { %>
        <div class="col-md-12">
          <div class="empty-state-box text-center">
            <p>Belum ada produk unggulan saat ini.</p>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</section>

<section class="section home-products-section">
  <div class="container">
    <div class="row">
      <div class="col-md-12">
        <div class="section-title">
          <h2 class="title">Recommended</h2>
        </div>
      </div>

      <% if (recommended && recommended.length) { %>
        <% recommended.forEach(function(product){ %>
          <div class="col-md-3 col-sm-6 col-xs-6">
            <%- include('partials/product-card', { product: product }) %>
          </div>
        <% }) %>
      <% } else { %>
        <div class="col-md-12">
          <div class="empty-state-box text-center">
            <p>Belum ada produk rekomendasi saat ini.</p>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</section>

<section class="section home-articles-section">
  <div class="container">
    <div class="row">
      <div class="col-md-12">
        <div class="section-title">
          <h2 class="title">Latest Articles</h2>
        </div>
      </div>

      <% if (articles && articles.length) { %>
        <% articles.forEach(function(article){ %>
          <div class="col-md-4 col-sm-6 col-xs-12">
            <article class="admin-card article-card home-article-card">
              <a href="/article/<%= article.slug %>" class="article-thumb-link">
                <img
                  src="<%= article.thumbnail %>"
                  alt="<%= article.title %>"
                  loading="lazy"
                >
              </a>

              <div class="article-card-content">
                <h3 class="article-card-title">
                  <a href="/article/<%= article.slug %>"><%= article.title %></a>
                </h3>
                <p class="article-card-excerpt"><%= article.excerpt %></p>
                <a href="/article/<%= article.slug %>" class="article-read-more">
                  Baca Selengkapnya <i class="fa fa-arrow-circle-right"></i>
                </a>
              </div>
            </article>
          </div>
        <% }) %>
      <% } else { %>
        <div class="col-md-12">
          <div class="empty-state-box text-center">
            <p>Belum ada artikel terbaru.</p>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
