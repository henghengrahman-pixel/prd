<header>
  <div id="top-header">
    <div class="container">
      <div class="row">
        <div class="col-md-6 col-xs-12">
          <ul class="header-links pull-left">
            <li>
              <a href="tel:<%= settings.phone || '' %>">
                <i class="fa fa-phone"></i>
                <%= settings.phone || '-' %>
              </a>
            </li>
            <li>
              <a href="mailto:<%= settings.email || '' %>">
                <i class="fa fa-envelope-o"></i>
                <%= settings.email || '-' %>
              </a>
            </li>
            <li>
              <a href="/contact">
                <i class="fa fa-map-marker"></i>
                <%= settings.address || 'Alamat toko' %>
              </a>
            </li>
          </ul>
        </div>

        <div class="col-md-6 col-xs-12">
          <ul class="header-links pull-right">
            <li>
              <a href="https://wa.me/<%= (settings.whatsapp || '').replace(/[^0-9]/g, '') %>" target="_blank" rel="noopener noreferrer">
                <i class="fa fa-whatsapp"></i>
                <%= settings.whatsapp || '-' %>
              </a>
            </li>
            <li>
              <a href="/admin/login">
                <i class="fa fa-user-o"></i>
                Admin
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <div id="header">
    <div class="container">
      <div class="row header-row">
        <div class="col-md-3">
          <div class="header-logo">
            <a href="/" class="logo">
              <img
                src="<%= settings.logo || 'https://via.placeholder.com/180x50?text=LOGO' %>"
                alt="<%= settings.storeName || settings.store_name || 'Store' %>">
            </a>
          </div>
        </div>

        <div class="col-md-6">
          <div class="header-search">
            <form method="get" action="/shop">
              <select class="input-select" name="category">
                <option value="">All Categories</option>
                <% (categories || []).forEach(function(cat){ %>
                  <option
                    value="<%= cat.name %>"
                    <%= (typeof category !== 'undefined' && category === cat.name) ? 'selected' : '' %>>
                    <%= cat.name %>
                  </option>
                <% }) %>
              </select>

              <input
                class="input"
                type="text"
                name="q"
                value="<%= typeof query !== 'undefined' ? query : '' %>"
                placeholder="Search here">

              <button class="search-btn" type="submit">Search</button>
            </form>
          </div>
        </div>

        <div class="col-md-3 clearfix">
          <div class="header-ctn">
            <div class="dropdown cart-wrap">
              <a class="dropdown-toggle" data-toggle="dropdown" aria-expanded="true" href="javascript:void(0)">
                <i class="fa fa-shopping-cart"></i>
                <span>Your Cart</span>
                <div class="qty"><%= cartCount || 0 %></div>
              </a>

              <div class="cart-dropdown">
                <div class="cart-list">
                  <% if (cart && cart.length) { %>
                    <% cart.slice(0, 3).forEach(function(item){ %>
                      <div class="product-widget">
                        <div class="product-img">
                          <img src="<%= item.thumbnail %>" alt="<%= item.name %>">
                        </div>
                        <div class="product-body">
                          <h3 class="product-name">
                            <a href="/product/<%= item.slug %>"><%= item.name %></a>
                          </h3>
                          <h4 class="product-price">
                            <span class="qty"><%= item.qty %>x</span>
                            THB <%= Number(item.price_thb || 0).toLocaleString('en-US') %>
                          </h4>
                        </div>
                      </div>
                    <% }) %>
                  <% } else { %>
                    <p class="empty-cart-text">Cart is empty.</p>
                  <% } %>
                </div>

                <div class="cart-summary">
                  <small><%= cartCount || 0 %> Item(s) selected</small>
                  <h5>SUBTOTAL: THB <%= Number((cartTotals && cartTotals.total_thb) || 0).toLocaleString('en-US') %></h5>
                </div>

                <div class="cart-btns">
                  <a href="/cart">View Cart</a>
                  <a href="/checkout">Checkout <i class="fa fa-arrow-circle-right"></i></a>
                </div>
              </div>
            </div>

            <div class="menu-toggle">
              <a href="#">
                <i class="fa fa-bars"></i>
                <span>Menu</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>

<nav id="navigation">
  <div class="container">
    <div id="responsive-nav">
      <ul class="main-nav nav navbar-nav">
        <li class="<%= currentPath === '/' ? 'active' : '' %>"><a href="/">Home</a></li>
        <li class="<%= currentPath && currentPath.startsWith('/shop') ? 'active' : '' %>"><a href="/shop">Shop</a></li>
        <li class="<%= currentPath && currentPath.startsWith('/articles') ? 'active' : '' %>"><a href="/articles">Artikel</a></li>
        <li class="<%= currentPath && currentPath.startsWith('/contact') ? 'active' : '' %>"><a href="/contact">Kontak</a></li>
        <li class="<%= currentPath && currentPath.startsWith('/cart') ? 'active' : '' %>"><a href="/cart">Cart</a></li>
      </ul>
    </div>
  </div>
</nav>

<div class="section flash-section">
  <div class="container">
    <% if (flash) { %>
      <div class="alert alert-<%= flash.type %> flash-alert"><%= flash.message %></div>
    <% } %>
  </div>
</div>
