<script>
  document.addEventListener('DOMContentLoaded', function () {
    var responsiveNav = document.getElementById('responsive-nav');
    var overlay = document.getElementById('mobile-nav-overlay');
    var body = document.body;

    var openBtnDesktop = document.getElementById('mobile-menu-toggle');
    var openBtnMobile = document.getElementById('mobile-menu-toggle-sticky');
    var closeBtn = document.getElementById('mobile-menu-close');

    function setExpanded(isOpen) {
      if (openBtnDesktop) openBtnDesktop.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      if (openBtnMobile) openBtnMobile.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    }

    function openMenu() {
      if (!responsiveNav) return;
      responsiveNav.classList.add('active');
      if (overlay) overlay.classList.add('active');
      body.classList.add('mobile-nav-open');
      setExpanded(true);
    }

    function closeMenu() {
      if (!responsiveNav) return;
      responsiveNav.classList.remove('active');
      if (overlay) overlay.classList.remove('active');
      body.classList.remove('mobile-nav-open');
      setExpanded(false);
    }

    if (openBtnDesktop) {
      openBtnDesktop.addEventListener('click', function (e) {
        e.preventDefault();
        openMenu();
      });
    }

    if (openBtnMobile) {
      openBtnMobile.addEventListener('click', function (e) {
        e.preventDefault();
        openMenu();
      });
    }

    if (closeBtn) {
      closeBtn.addEventListener('click', function () {
        closeMenu();
      });
    }

    if (overlay) {
      overlay.addEventListener('click', function () {
        closeMenu();
      });
    }

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') closeMenu();
    });

    var navLinks = document.querySelectorAll('#responsive-nav .main-nav a');
    navLinks.forEach(function (link) {
      link.addEventListener('click', function () {
        closeMenu();
      });
    });
  });
</script>
