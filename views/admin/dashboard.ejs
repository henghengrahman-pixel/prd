<%- include('../partials/head') %>
<main class="admin-shell">
  <%- include('partials/nav') %>
  <section class="admin-content">
    <h1>Dashboard</h1>
    <% if (flashSuccess && flashSuccess.length) { %><div class="flash success"><%= flashSuccess[0] %></div><% } %>
    <div class="stats-grid">
      <div class="stat-card"><strong><%= stats.posts %></strong><span>Posts</span></div>
      <div class="stat-card"><strong><%= stats.pages %></strong><span>Pages</span></div>
      <div class="stat-card"><strong><%= stats.categories %></strong><span>Categories</span></div>
      <div class="stat-card"><strong><%= stats.media %></strong><span>Media</span></div>
    </div>
  </section>
</main>
<%- include('../partials/footer') %>
