<%- include('partials-top') %><div class="row"><div class="col-md-4"><div class="admin-card"><h3>Total Products</h3><p><%= totalProducts %></p></div></div><div class="col-md-4"><div class="admin-card"><h3>Total Orders</h3><p><%= totalOrders %></p></div></div><div class="col-md-4"><div class="admin-card"><h3>Total Articles</h3><p><%= totalArticles %></p></div></div><div class="col-md-12"><div class="admin-card"><h3>Recent Orders</h3><div class="table-responsive"><table class="table table-bordered"><tr><th>ID</th><th>Customer</th><th>Status</th><th>Total THB</th></tr><% recentOrders.forEach(function(order){ %><tr><td><%= order.id %></td><td><%= order.customer_name %></td><td><%= order.status %></td><td><%= order.total_thb.toLocaleString('en-US') %></td></tr><% }) %></table></div></div></div></div><%- include('partials-bottom') %>