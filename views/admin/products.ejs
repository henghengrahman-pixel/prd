<%- include('partials-top') %><div class="admin-card"><div class="clearfix"><h3 class="pull-left">Products</h3><a href="/admin/products/create" class="primary-btn pull-right">Add Product</a></div><div class="table-responsive mt-15"><table class="table table-bordered"><tr><th>Name</th><th>Status</th><th>Category</th><th>Price THB</th><th>Visible</th><th>Actions</th></tr><% products.forEach(function(item){ %><tr><td><%= item.name %></td><td><%= item.status %></td><td><%= item.category %></td><td><%= item.price_thb.toLocaleString('en-US') %></td><td><%= item.visible ? 'Yes' : 'No' %></td><td class="table-actions"><a class="btn btn-xs btn-default" href="/admin/products/<%= item.id %>/edit">Edit</a> <form method="post" action="/admin/products/<%= item.id %>/delete"><button class="btn btn-xs btn-danger">Delete</button></form></td></tr><% }) %></table></div></div><%- include('partials-bottom') %>