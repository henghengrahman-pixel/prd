<%- include('partials-top') %><div class="admin-card"><h3>Orders</h3><div class="table-responsive"><table class="table table-bordered"><tr><th>ID</th><th>Customer</th><th>WhatsApp</th><th>Total</th><th>Status</th><th>Items</th><th>Action</th></tr><% orders.forEach(function(order){ %><tr><td><%= order.id %></td><td><%= order.customer_name %></td><td><%= order.whatsapp %></td><td>THB <%= order.total_thb.toLocaleString('en-US') %><br>IDR <%= order.total_idr.toLocaleString('en-US') %></td><td><%= order.status %></td><td><ul><% order.items.forEach(function(item){ %><li><%= item.name %> x<%= item.qty %></li><% }) %></ul></td><td><form method="post" action="/admin/orders/<%= order.id %>/status"><select class="input" name="status"><% statuses.forEach(function(status){ %><option value="<%= status %>" <%= order.status===status?'selected':'' %>><%= status %></option><% }) %></select><button class="btn btn-primary btn-sm mt-15">Update</button></form></td></tr><% }) %></table></div></div><%- include('partials-bottom') %>