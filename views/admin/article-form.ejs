<%- include('partials-top') %><div class="admin-card"><h3><%= item ? 'Edit Article' : 'Create Article' %></h3><form method="post" action="<%= item ? '/admin/articles/' + item.id + '/edit' : '/admin/articles/create' %>"><div class="form-group"><label>Title</label><input class="input" name="title" value="<%= item?.title || '' %>"></div><div class="form-group"><label>Slug</label><input class="input" name="slug" value="<%= item?.slug || '' %>"></div><div class="form-group"><label>Excerpt</label><textarea class="input" name="excerpt"><%= item?.excerpt || '' %></textarea></div><div class="form-group"><label>Thumbnail URL</label><input class="input" name="thumbnail" value="<%= item?.thumbnail || '' %>"></div><div class="form-group"><label>Content HTML</label><textarea class="input textarea-lg" name="content"><%= item?.content || '' %></textarea></div><label><input type="checkbox" name="visible" <%= item?.visible !== false ? 'checked' : '' %>> Visible</label><div class="mt-15"><button class="primary-btn">Save</button></div></form></div><%- include('partials-bottom') %>