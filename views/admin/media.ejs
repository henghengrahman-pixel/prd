<%- include('../partials/head') %>
<main class="admin-shell">
  <%- include('partials/nav') %>
  <section class="admin-content">
    <h1>Media</h1>
    <div class="admin-grid-two">
      <form method="post" action="<%= baseUrl %>/<%= adminPath %>/media" enctype="multipart/form-data" class="panel-card">
        <h2>Upload Media</h2>
        <input type="file" name="mediaFiles" multiple required>
        <button class="cta-button" type="submit">Upload</button>
      </form>
      <div class="panel-card">
        <h2>Daftar Media</h2>
        <% media.forEach((item) => { %>
          <div class="row-like media-row">
            <div>
              <strong><%= item.name %></strong>
              <small><%= item.url %></small>
            </div>
            <div class="media-actions">
              <a class="mini-button" href="<%= item.url %>" target="_blank">Buka</a>
              <form method="post" action="<%= baseUrl %>/<%= adminPath %>/media/<%= item.id %>/delete" onsubmit="return confirm('Hapus media ini?')">
                <button class="danger-btn" type="submit">Hapus</button>
              </form>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  </section>
</main>
<%- include('../partials/footer') %>
