<%- include('partials-top', { pageTitle: item ? 'Edit Product' : 'Create Product', pageDescription: 'Isi data produk dengan lengkap. Slug akan otomatis dibuat jika dikosongkan.' }) %>
<div class="admin-card">
  <form method="post" action="<%= item ? '/admin/products/' + item.id + '/edit' : '/admin/products/create' %>" class="admin-form">
    <div class="row">
      <div class="col-md-8">
        <div class="row">
          <div class="col-md-6">
            <div class="form-group">
              <label>Name</label>
              <input class="input" name="name" value="<%= item?.name || '' %>" required>
            </div>
          </div>
          <div class="col-md-6">
            <div class="form-group">
              <label>Slug</label>
              <input class="input" name="slug" value="<%= item?.slug || '' %>" placeholder="otomatis jika kosong">
            </div>
          </div>
          <div class="col-md-6">
            <div class="form-group">
              <label>Category</label>
              <input class="input" name="category" value="<%= item?.category || '' %>" required>
            </div>
          </div>
          <div class="col-md-6">
            <div class="form-group">
              <label>Brand</label>
              <input class="input" name="brand" value="<%= item?.brand || '' %>">
            </div>
          </div>
          <div class="col-md-4">
            <div class="form-group">
              <label>Status</label>
              <select class="input" name="status">
                <option value="ready" <%= item?.status === 'ready' ? 'selected' : '' %>>ready</option>
                <option value="sold_out" <%= item?.status === 'sold_out' ? 'selected' : '' %>>sold_out</option>
              </select>
            </div>
          </div>
          <div class="col-md-4">
            <div class="form-group">
              <label>Price THB</label>
              <input class="input" type="number" min="0" step="0.01" name="price_thb" value="<%= item?.price_thb ?? 0 %>">
            </div>
          </div>
          <div class="col-md-4">
            <div class="form-group">
              <label>Price IDR</label>
              <input class="input" type="number" min="0" step="0.01" name="price_idr" value="<%= item?.price_idr ?? 0 %>">
            </div>
          </div>
          <div class="col-md-6">
            <div class="form-group">
              <label>Compare Price THB</label>
              <input class="input" type="number" min="0" step="0.01" name="compare_price_thb" value="<%= item?.compare_price_thb ?? 0 %>">
            </div>
          </div>
          <div class="col-md-6">
            <div class="form-group">
              <label>Compare Price IDR</label>
              <input class="input" type="number" min="0" step="0.01" name="compare_price_idr" value="<%= item?.compare_price_idr ?? 0 %>">
            </div>
          </div>
          <div class="col-md-12">
            <div class="form-group">
              <label>Thumbnail URL</label>
              <input class="input" type="url" name="thumbnail" value="<%= item?.thumbnail || '' %>" placeholder="https://...">
            </div>
          </div>
          <div class="col-md-12">
            <div class="form-group">
              <label>Images URL (pisahkan dengan baris baru atau koma)</label>
              <textarea class="input textarea-lg" name="images" placeholder="https://image-1.com&#10;https://image-2.com"><%= item?.images?.join('\n') || '' %></textarea>
            </div>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="admin-card" style="margin-bottom:0;background:#fafbff;">
          <div class="admin-card-title"><h4>Visibility & Flags</h4></div>
          <div class="admin-check-grid">
            <label class="admin-check"><input type="checkbox" name="featured" <%= item?.featured ? 'checked' : '' %>> Featured</label>
            <label class="admin-check"><input type="checkbox" name="recommended" <%= item?.recommended ? 'checked' : '' %>> Recommended</label>
            <label class="admin-check"><input type="checkbox" name="visible" <%= item?.visible !== false ? 'checked' : '' %>> Visible</label>
          </div>
          <hr>
          <div class="form-group">
            <label>Preview Thumbnail</label>
            <img class="admin-thumb-preview" src="<%= item?.thumbnail || 'https://dummyimage.com/400x280/f1f5f9/64748b&text=Preview' %>" alt="Preview">
          </div>
        </div>
      </div>
      <div class="col-md-12">
        <div class="form-group">
          <label>Short Description</label>
          <textarea class="input" name="short_description"><%= item?.short_description || '' %></textarea>
        </div>
      </div>
      <div class="col-md-12">
        <div class="form-group">
          <label>Description HTML</label>
          <textarea class="input textarea-lg" name="description"><%= item?.description || '' %></textarea>
        </div>
      </div>
      <div class="col-md-12">
        <div class="form-group">
          <label>Details HTML</label>
          <textarea class="input textarea-lg" name="details"><%= item?.details || '' %></textarea>
        </div>
      </div>
      <div class="col-md-12">
        <div class="admin-actions">
          <button class="primary-btn" type="submit"><%= item ? 'Update Product' : 'Save Product' %></button>
          <a href="/admin/products" class="btn btn-default">Back</a>
        </div>
      </div>
    </div>
  </form>
</div>
<%- include('partials-bottom') %>
