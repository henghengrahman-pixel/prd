<%- include('../partials/head') %>
<main class="admin-shell">
  <%- include('partials/nav') %>
  <section class="admin-content">
    <h1>Categories</h1>
    <div class="admin-grid-two">
      <form method="post" action="<%= baseUrl %>/<%= adminPath %>/categories" class="panel-card">
        <h2>Tambah Kategori</h2>
        <label>Nama</label><input name="name" required>
        <label>Slug</label><input name="slug">
        <label>Description</label><textarea name="description"></textarea>
        <button class="cta-button" type="submit">Tambah Kategori</button>
      </form>
      <div class="panel-card">
        <h2>Daftar Kategori</h2>
        <% categories.forEach((category) => { %>
          <div class="row-like">
            <div>
              <strong><%= category.name %></strong>
              <small><%= category.id %> • <%= category.slug %></small>
            </div>
            <form method="post" action="<%= baseUrl %>/<%= adminPath %>/categories/<%= category.id %>/delete" onsubmit="return confirm('Hapus kategori ini?')">
              <button class="danger-btn" type="submit">Hapus</button>
            </form>
          </div>
        <% }) %>
      </div>
    </div>
  </section>
</main>
<%- include('../partials/footer') %>
