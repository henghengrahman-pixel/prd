<%- include('partials-top', { pageTitle: 'Settings', pageDescription: 'Atur identitas toko, kontak, dan SEO default website.' }) %>

<div class="admin-card">
  <form method="post" action="/admin/settings" class="admin-form">
    <div class="row">
      <div class="col-md-6">
        <div class="form-group">
          <label>Store Name</label>
          <input class="input" name="storeName" value="<%= settings.storeName || '' %>" required>
        </div>
      </div>

      <div class="col-md-6">
        <div class="form-group">
          <label>Logo URL</label>
          <input class="input" name="logo" value="<%= settings.logo || '' %>">
        </div>
      </div>

      <div class="col-md-4">
        <div class="form-group">
          <label>WhatsApp</label>
          <input class="input" name="whatsapp" value="<%= settings.whatsapp || '' %>" placeholder="628xxxx / 08xxxx">
        </div>
      </div>

      <div class="col-md-4">
        <div class="form-group">
          <label>Telegram Username</label>
          <input class="input" name="telegram" value="<%= settings.telegram || '' %>" placeholder="@namatoko atau namatoko">
        </div>
      </div>

      <div class="col-md-4">
        <div class="form-group">
          <label>Email</label>
          <input class="input" name="email" value="<%= settings.email || '' %>">
        </div>
      </div>

      <div class="col-md-6">
        <div class="form-group">
          <label>Telegram Channel / Grup</label>
          <input class="input" name="telegramChannel" value="<%= settings.telegramChannel || '' %>" placeholder="@channeltoko atau channeltoko">
        </div>
      </div>

      <div class="col-md-6">
        <div class="form-group">
          <label>Address</label>
          <input class="input" name="address" value="<%= settings.address || '' %>">
        </div>
      </div>

      <div class="col-md-12">
        <hr>
        <h4>SEO Default</h4>
      </div>

      <div class="col-md-6">
        <div class="form-group">
          <label>Meta Title</label>
          <input class="input" name="metaTitle" value="<%= settings.seo && settings.seo.metaTitle ? settings.seo.metaTitle : '' %>">
        </div>
      </div>

      <div class="col-md-6">
        <div class="form-group">
          <label>OG Image</label>
          <input class="input" name="ogImage" value="<%= settings.seo && settings.seo.ogImage ? settings.seo.ogImage : '' %>">
        </div>
      </div>

      <div class="col-md-12">
        <div class="form-group">
          <label>Meta Description</label>
          <textarea class="input" name="metaDescription"><%= settings.seo && settings.seo.metaDescription ? settings.seo.metaDescription : '' %></textarea>
        </div>
      </div>

      <div class="col-md-12">
        <div class="form-group">
          <label>Keywords</label>
          <input class="input" name="keywords" value="<%= settings.seo && settings.seo.keywords ? settings.seo.keywords : '' %>">
        </div>
      </div>

      <div class="col-md-12">
        <button class="primary-btn" type="submit">Save Settings</button>
      </div>
    </div>
  </form>
</div>

<%- include('partials-bottom') %>
