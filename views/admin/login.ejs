<%- include('../partials/head') %>
<main class="admin-login-wrap">
  <form method="post" action="<%= baseUrl %>/<%= adminPath %>/login" class="login-card">
    <img src="<%= settings.logo || '/images/default-logo.svg' %>" class="login-logo" alt="Logo">
    <h1>Admin Login</h1>
    <% if (flashError && flashError.length) { %><div class="flash error"><%= flashError[0] %></div><% } %>
    <% if (flashSuccess && flashSuccess.length) { %><div class="flash success"><%= flashSuccess[0] %></div><% } %>
    <label>Username</label>
    <input type="text" name="username" required>
    <label>Password</label>
    <input type="password" name="password" required>
    <button type="submit" class="cta-button">Masuk</button>
  </form>
</main>
<%- include('../partials/footer') %>
