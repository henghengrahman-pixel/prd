<%- include('partials-top') %><div class="admin-card"><div class="clearfix"><h3 class="pull-left">Articles</h3><a href="/admin/articles/create" class="primary-btn pull-right">Add Article</a></div><div class="table-responsive mt-15"><table class="table table-bordered"><tr><th>Title</th><th>Slug</th><th>Visible</th><th>Actions</th></tr><% articles.forEach(function(item){ %><tr><td><%= item.title %></td><td><%= item.slug %></td><td><%= item.visible ? 'Yes' : 'No' %></td><td class="table-actions"><a class="btn btn-xs btn-default" href="/admin/articles/<%= item.id %>/edit">Edit</a> <form method="post" action="/admin/articles/<%= item.id %>/delete"><button class="btn btn-xs btn-danger">Delete</button></form></td></tr><% }) %></table></div></div><%- include('partials-bottom') %>