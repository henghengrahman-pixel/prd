<%- include('partials/head') %>
<%- include('partials/header') %>
<div class="section"><div class="container"><div class="row"><div class="col-md-12"><div class="section-title"><h3 class="title">Your Cart</h3></div></div>
<% if (!cart.length) { %><div class="col-md-12"><div class="empty-box">Keranjang kosong.</div></div><% } else { %>
<div class="col-md-8"><form method="post" action="/cart/update"><div class="table-responsive"><table class="table table-bordered"><thead><tr><th>Produk</th><th>Harga</th><th>Qty</th><th>Total</th><th></th></tr></thead><tbody>
<% cart.forEach(function(item){ %>
<tr>
  <td><img src="<%= item.thumbnail %>" alt="<%= item.name %>" style="width:70px;height:70px;object-fit:cover;margin-right:10px;"> <%= item.name %></td>
  <td>THB <%= item.price_thb.toLocaleString('en-US') %><br>IDR <%= item.price_idr.toLocaleString('en-US') %></td>
  <td><input type="number" class="input" name="qty[<%= item.product_id %>]" min="1" value="<%= item.qty %>"></td>
  <td>THB <%= item.line_total_thb.toLocaleString('en-US') %><br>IDR <%= item.line_total_idr.toLocaleString('en-US') %></td>
  <td><form method="post" action="/cart/remove/<%= item.product_id %>"><button class="btn btn-danger btn-sm">Remove</button></form></td>
</tr>
<% }) %></tbody></table></div><button class="primary-btn">Update Cart</button></form></div>
<div class="col-md-4"><div class="admin-card"><h3>Summary</h3><p>Total THB: <strong><%= cartTotals.total_thb.toLocaleString('en-US') %></strong></p><p>Total IDR: <strong><%= cartTotals.total_idr.toLocaleString('en-US') %></strong></p><a href="/checkout" class="primary-btn">Proceed to checkout</a></div></div>
<% } %></div></div></div>
<%- include('partials/footer') %>
