<%- include('partials/head') %>
<%- include('partials/header') %>

<section class="section cart-page-section">
  <div class="container">
    <div class="cart-page-header">
      <div class="section-title">
        <h1 class="title">Keranjang Belanja</h1>
      </div>
      <p class="cart-page-subtitle">
        Cek kembali produk pilihanmu sebelum lanjut ke checkout.
      </p>
    </div>

    <% if (!cart.length) { %>
      <div class="empty-box text-center cart-empty-state">
        <h3>Keranjang kosong</h3>
        <p>Belum ada produk di keranjang. Yuk pilih produk terbaik untuk kamu.</p>
        <a href="/shop" class="primary-btn">Mulai Belanja</a>
      </div>
    <% } else { %>
      <div class="row cart-page-row">
        <div class="col-md-8 col-sm-12 col-xs-12">
          <form method="post" action="/cart/update" class="cart-update-form">
            <div class="cart-items-card">
              <div class="cart-table-responsive">
                <table class="table cart-table">
                  <thead>
                    <tr>
                      <th>Produk</th>
                      <th>Harga</th>
                      <th>Qty</th>
                      <th>Total</th>
                      <th>Aksi</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% cart.forEach(function(item){ %>
                      <tr>
                        <td>
                          <div class="cart-product-cell">
                            <a href="/product/<%= item.slug || '' %>" class="cart-product-thumb">
                              <img src="<%= item.thumbnail %>" alt="<%= item.name %>">
                            </a>
                            <div class="cart-product-info">
                              <h3 class="cart-product-name">
                                <% if (item.slug) { %>
                                  <a href="/product/<%= item.slug %>"><%= item.name %></a>
                                <% } else { %>
                                  <span><%= item.name %></span>
                                <% } %>
                              </h3>
                            </div>
                          </div>
                        </td>

                        <td>
                          <div class="cart-price-block">
                            <span>THB <%= item.price_thb.toLocaleString('en-US') %></span>
                            <small>IDR <%= item.price_idr.toLocaleString('en-US') %></small>
                          </div>
                        </td>

                        <td>
                          <input
                            type="number"
                            class="input cart-qty-input"
                            name="qty[<%= item.product_id %>]"
                            min="1"
                            value="<%= item.qty %>"
                          >
                        </td>

                        <td>
                          <div class="cart-price-block">
                            <strong>THB <%= item.line_total_thb.toLocaleString('en-US') %></strong>
                            <small>IDR <%= item.line_total_idr.toLocaleString('en-US') %></small>
                          </div>
                        </td>

                        <td>
                          <button
                            type="submit"
                            class="cart-remove-btn"
                            formaction="/cart/remove/<%= item.product_id %>"
                            formmethod="post"
                          >
                            Hapus
                          </button>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>

              <div class="cart-actions-bottom">
                <button type="submit" class="primary-btn">Update Cart</button>
                <a href="/shop" class="cart-continue-link">Lanjut Belanja</a>
              </div>
            </div>
          </form>
        </div>

        <div class="col-md-4 col-sm-12 col-xs-12">
          <div class="cart-summary-card">
            <h3 class="cart-summary-title">Ringkasan Belanja</h3>

            <div class="cart-summary-line">
              <span>Total THB</span>
              <strong><%= cartTotals.total_thb.toLocaleString('en-US') %></strong>
            </div>

            <div class="cart-summary-line">
              <span>Total IDR</span>
              <strong><%= cartTotals.total_idr.toLocaleString('en-US') %></strong>
            </div>

            <div class="cart-summary-actions">
              <a href="/checkout" class="primary-btn cart-checkout-btn">
                Proceed to Checkout
              </a>
            </div>
          </div>
        </div>
      </div>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>
