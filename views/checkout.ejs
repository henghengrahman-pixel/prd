<%- include('partials/head') %>
<%- include('partials/header') %>
<div class="section"><div class="container"><div class="row"><div class="col-md-7"><div class="billing-details"><div class="section-title"><h3 class="title">Checkout</h3></div>
<form method="post" action="/checkout">
  <div class="form-group"><input class="input" name="customer_name" placeholder="Nama" required></div>
  <div class="form-group"><input class="input" name="whatsapp" placeholder="WhatsApp" required></div>
  <div class="form-group"><textarea class="input" name="address" placeholder="Alamat" required></textarea></div>
  <div class="form-group"><textarea class="input" name="note" placeholder="Catatan"></textarea></div>
  <button class="primary-btn order-submit">Place order</button>
</form>
</div></div><div class="col-md-5 order-details"><div class="section-title text-center"><h3 class="title">Order Summary</h3></div><div class="order-summary">
  <div class="order-col"><div><strong>PRODUCT</strong></div><div><strong>TOTAL</strong></div></div><div class="order-products">
  <% cart.forEach(function(item){ %><div class="order-col"><div><%= item.qty %>x <%= item.name %></div><div>THB <%= item.line_total_thb.toLocaleString('en-US') %></div></div><% }) %>
  </div>
  <div class="order-col"><div><strong>TOTAL THB</strong></div><div><strong class="order-total"><%= cartTotals.total_thb.toLocaleString('en-US') %></strong></div></div>
  <div class="order-col"><div><strong>TOTAL IDR</strong></div><div><strong class="order-total"><%= cartTotals.total_idr.toLocaleString('en-US') %></strong></div></div>
</div></div></div></div></div>
<%- include('partials/footer') %>
